{
  "name": "ledger-book-poc",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun --filter '@ledger-book/api' --filter '@ledger-book/web' --filter '@ledger-book/agent' --parallel dev",
    "build": "bun --filter '@ledger-book/contracts' typecheck && bun --filter '@ledger-book/api' build && bun --filter '@ledger-book/web' build && bun --filter '@ledger-book/agent' build",
    "test": "bun --filter '@ledger-book/api' test && bun --filter '@ledger-book/web' test",
    "typecheck": "bun --filter '@ledger-book/contracts' typecheck && bun --filter '@ledger-book/api' typecheck && bun --filter '@ledger-book/web' typecheck && bun --filter '@ledger-book/agent' typecheck",
    "lint": "oxlint apps packages",
    "lint:fix": "oxlint --fix apps packages",
    "format": "oxfmt apps packages",
    "format:check": "oxfmt --check apps packages",
    "agent:dev": "bun --filter '@ledger-book/agent' dev",
    "agent:build": "bun --filter '@ledger-book/agent' build",
    "agent:deploy": "bun --filter '@ledger-book/agent' deploy",
    "db:generate": "bun --filter '@ledger-book/api' db:generate",
    "db:migrate": "bun --filter '@ledger-book/api' db:migrate",
    "db:push": "bun --filter '@ledger-book/api' db:push",
    "db:studio": "bun --filter '@ledger-book/api' db:studio",
    "c4:view": "bunx likec4@1.53.0 serve docs/architecture",
    "c4:validate": "bunx likec4@1.53.0 validate --json --no-layout --file docs/architecture/ledger-book.c4 docs/architecture",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "lefthook": "2.1.10",
    "oxfmt": "0.58.0",
    "oxlint": "1.73.0",
    "typescript": "5.9.3",
    "vue-tsc": "3.3.7"
  }
}
