{
  "name": "@ledger-book/agent",
  "private": true,
  "description": "CMoney 持股分析 Agent — AgentCore Runtime (Node 22)",
  "type": "module",
  "scripts": {
    "dev": "bun --watch src/agent.ts",
    "build": "bun build ./src/agent.ts --outdir ./dist --target node --env-file .env",
    "typecheck": "tsc --noEmit",
    "package": "bun run build && cd dist && zip -r ../deployment_package.zip agent.js",
    "deploy": "bun run package && bun scripts/deploy.mjs",
    "ingest": "bun scripts/ingest-opensearch.ts"
  },
  "dependencies": {
    "@aws-crypto/sha256-js": "^5.2.0",
    "@aws-sdk/client-bedrock-runtime": "^3.750.0",
    "@aws-sdk/credential-provider-node": "^3.750.0",
    "@smithy/protocol-http": "^5.0.0",
    "@smithy/signature-v4": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "22.16.4"
  }
}
