# Agent (apps/agent)
OPENSEARCH_ENDPOINT=https://your-opensearch-collection.us-east-1.aoss.amazonaws.com
AWS_REGION=us-east-1

# API (apps/api)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ledger_book?schema=public
AGENT_ENDPOINT=http://localhost:8080
# Production only (set via Terraform):
# AGENT_RUNTIME_ARN=arn:aws:bedrock-agentcore:us-east-1:123456789012:agent-runtime/xxxxx
# AGENT_ENDPOINT_QUALIFIER=cmoney_stock_node_ep

# Web (apps/web)
API_PROXY_TARGET=http://localhost:3000
# Keep mock mode until the /api/v1 adapter in apps/web/src/services/client.ts is implemented.
VITE_API_MODE=mock
VITE_API_BASE_URL=/api/v1
